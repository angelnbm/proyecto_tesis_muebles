{
  "version": 2,
  "buildCommand": "cd backend && npm install && cd ../frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...all]"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
